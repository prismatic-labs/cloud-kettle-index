---
const requests = [
  {
    need: "Measured Dominion-zone data-centre load",
    holder: "Dominion Energy Virginia / Virginia SCC filings",
    status: "Missing",
    next: "Ask for hourly or monthly data-centre load by tariff/customer class, aggregated enough to protect customers.",
  },
  {
    need: "Dominion service-territory boundary as GIS",
    holder: "Dominion Energy Virginia / Virginia SCC",
    status: "Missing",
    next: "Ask for a public polygon or shapefile suitable for non-operational mapping.",
  },
  {
    need: "Northern Virginia county-level data-centre load",
    holder: "Counties, PJM interconnection queues, utilities",
    status: "Missing",
    next: "Ask Loudoun, Fairfax, Prince William, and Arlington for planning assumptions and utility-impact evidence.",
  },
  {
    need: "Measured regional data-centre load shapes",
    holder: "Dominion, PJM, operators, research partners",
    status: "Missing",
    next: "Ask for anonymised hourly profiles analogous to the UKPN data-centre profile release.",
  },
  {
    need: "Latest PJM demand denominator",
    holder: "EIA Balancing Authority Areas hourly data",
    status: "Wired",
    next: "Let the scheduled EIA refresh populate the static cache; label as latest-reported, not live.",
  },
];
---

<section class="max-w-4xl mx-auto px-4 pb-8">
  <div class="border border-gray-200 rounded bg-white px-6 py-6">
    <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
      <div>
        <h2 class="text-xl font-semibold mb-1">Data request scoreboard</h2>
        <p class="text-sm text-gray-600 max-w-2xl leading-relaxed">
          The estimate is useful, but the missing data is the real story. These are the records
          that would most improve the DC + Mid-Atlantic index.
        </p>
      </div>
      <a
        href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/records-us`}
        class="inline-block bg-gray-800 text-white text-sm font-medium px-4 py-2 rounded hover:bg-gray-700 transition-colors"
      >
        Help make the US data open
      </a>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="text-left py-2 pr-5 font-semibold text-gray-700">Missing or partial data</th>
            <th class="text-left py-2 pr-5 font-semibold text-gray-700">Likely holder</th>
            <th class="text-left py-2 pr-5 font-semibold text-gray-700">Status</th>
            <th class="text-left py-2 font-semibold text-gray-700">Next request</th>
          </tr>
        </thead>
        <tbody>
          {requests.map(item => (
            <tr class="border-b border-gray-100 align-top">
              <td class="py-3 pr-5 text-gray-700 font-medium">{item.need}</td>
              <td class="py-3 pr-5 text-gray-500">{item.holder}</td>
              <td class="py-3 pr-5">
                <span class:list={[
                  "inline-block rounded px-2 py-0.5 text-xs font-medium",
                  item.status === "Wired"
                    ? "bg-emerald-50 text-emerald-700"
                    : "bg-amber-50 text-amber-700",
                ]}>
                  {item.status}
                </span>
              </td>
              <td class="py-3 text-gray-500">{item.next}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
