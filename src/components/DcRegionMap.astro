---

{compact ? (
<figure>
  <svg
    viewBox="0 0 640 360"
    role="img"
    aria-labelledby="dc-region-map-title-c dc-region-map-desc-c"
    class="w-full h-auto rounded"
  >
    <title id="dc-region-map-title-c">Northern Virginia and Washington DC county locator map</title>
    <desc id="dc-region-map-desc-c">
      Census county-boundary map highlighting Loudoun, Fairfax, and Prince William counties, with the District of Columbia shown separately.
    </desc>
    <rect width="640" height="360" fill="#f8fafc" rx="10" />
    {contextPaths.map(d => (
      <path d={d} fill="#eef2f7" stroke="#cbd5e1" stroke-width="1.2" />
    ))}
    {focusCounties.map(county => (
      <path d={county.d} fill="#1f2937" stroke="#ffffff" stroke-width="1.6">
        <title>{county.name}</title>
      </path>
    ))}
    {secondaryCounties.map(county => (
      <path d={county.d} fill="#64748b" stroke="#ffffff" stroke-width="1.4">
        <title>{county.name}</title>
      </path>
    ))}
    <path d={dcPath} fill="#fbbf24" stroke="#92400e" stroke-width="1.5">
      <title>District of Columbia</title>
    </path>
    <g stroke-width="1.2" stroke-linecap="round">
      <line x1="151" y1="128" x2="86" y2="88" stroke="#1f2937" />
      <line x1="214" y1="189" x2="345" y2="200" stroke="#1f2937" />
      <line x1="170" y1="215" x2="84" y2="258" stroke="#1f2937" />
      <line x1="248" y1="172" x2="346" y2="174" stroke="#64748b" />
      <line x1="280" y1="172" x2="346" y2="142" stroke="#92400e" />
    </g>
    <g class="text-[13px] font-semibold">
      <text x="34" y="83" class="fill-gray-800">Loudoun</text>
      <text x="349" y="204" class="fill-gray-800">Fairfax</text>
      <text x="31" y="263" class="fill-gray-800">Prince William</text>
      <text x="349" y="178" class="fill-slate-500">Arlington</text>
      <text x="349" y="146" class="fill-amber-700">DC</text>
    </g>
    <text x="306" y="113" class="fill-gray-400 text-[12px]">Maryland</text>
    <text x="49" y="289" class="fill-gray-400 text-[12px]">Virginia</text>
  </svg>
  <figcaption class="mt-1.5 text-[11px] text-gray-400 leading-relaxed">
    Loudoun, Fairfax, Prince William — the Northern Virginia data-centre cluster.
    Data covers Dominion's wider service territory, not these county boundaries alone.
  </figcaption>
</figure>
) : (
<section class="max-w-4xl mx-auto px-4 pb-8">
  <div class="border border-gray-200 rounded bg-white px-6 py-5">
    <div class="grid grid-cols-1 md:grid-cols-[1.1fr_0.9fr] gap-6 items-center">
      <div>
        <h2 class="text-base font-semibold mb-2">Locator: Northern Virginia focus counties</h2>
        <p class="text-sm text-gray-600 leading-relaxed">
          The highlighted counties are the Northern Virginia data-centre cluster most relevant to
          DC readers: Loudoun, Fairfax, and Prince William. Arlington is shown as nearby Northern
          Virginia context, but not as a main data-centre-density county. The published demand data
          covers Dominion Energy Virginia&rsquo;s wider service territory, not these county boundaries alone.
        </p>
        <div class="mt-4 border-l-2 border-slate-300 pl-3 text-xs text-gray-500 leading-relaxed">
          For the full utility footprint, use Dominion&rsquo;s service-area locator or Virginia SCC&rsquo;s
          regulated company/service map. This page does not draw a service-territory polygon because
          I have not found a public open boundary file suitable for reuse.
          <span class="block mt-1">
            <a
              href="https://www.dominionenergy.com/economic-development/virginia/service-area-locator"
              target="_blank"
              rel="noopener"
              class="underline hover:text-gray-700"
            >
              Dominion locator
            </a>
            <span class="text-gray-300 px-1">/</span>
            <a
              href="https://www.scc.virginia.gov/consumers/public-utility/electricity-faqs/regulated-companies-service-map/"
              target="_blank"
              rel="noopener"
              class="underline hover:text-gray-700"
            >
              Virginia SCC map
            </a>
          </span>
        </div>
        <dl class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-xs text-gray-500">
          <div class="flex items-center gap-2">
            <span class="inline-block h-3 w-3 rounded-sm bg-gray-800"></span>
            <span>Main focus counties</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block h-3 w-3 rounded-sm bg-slate-400"></span>
            <span>Nearby context county</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block h-3 w-3 rounded-sm bg-amber-300"></span>
            <span>District of Columbia</span>
          </div>
        </dl>
      </div>

      <figure>
        <svg
          viewBox="0 0 640 360"
          role="img"
          aria-labelledby="dc-region-map-title dc-region-map-desc"
          class="w-full h-auto"
        >
          <title id="dc-region-map-title">Northern Virginia and Washington DC county locator map</title>
          <desc id="dc-region-map-desc">
            Census county-boundary map highlighting Loudoun, Fairfax, and Prince William counties, with the District of Columbia shown separately.
          </desc>
          <rect width="640" height="360" fill="#f8fafc" rx="10" />
          {contextPaths.map(d => (
            <path d={d} fill="#eef2f7" stroke="#cbd5e1" stroke-width="1.2" />
          ))}
          {focusCounties.map(county => (
            <path d={county.d} fill="#1f2937" stroke="#ffffff" stroke-width="1.6">
              <title>{county.name}</title>
            </path>
          ))}
          {secondaryCounties.map(county => (
            <path d={county.d} fill="#64748b" stroke="#ffffff" stroke-width="1.4">
              <title>{county.name}</title>
            </path>
          ))}
          <path d={dcPath} fill="#fbbf24" stroke="#92400e" stroke-width="1.5">
            <title>District of Columbia</title>
          </path>

          <g stroke-width="1.2" stroke-linecap="round">
            <line x1="151" y1="128" x2="86" y2="88" stroke="#1f2937" />
            <line x1="214" y1="189" x2="345" y2="200" stroke="#1f2937" />
            <line x1="170" y1="215" x2="84" y2="258" stroke="#1f2937" />
            <line x1="248" y1="172" x2="346" y2="174" stroke="#64748b" />
            <line x1="280" y1="172" x2="346" y2="142" stroke="#92400e" />
          </g>
          <g class="text-[13px] font-semibold">
            <text x="34" y="83" class="fill-gray-800">Loudoun</text>
            <text x="349" y="204" class="fill-gray-800">Fairfax</text>
            <text x="31" y="263" class="fill-gray-800">Prince William</text>
            <text x="349" y="178" class="fill-slate-500">Arlington</text>
            <text x="349" y="146" class="fill-amber-700">DC</text>
          </g>
          <text x="306" y="113" class="fill-gray-400 text-[12px]">Maryland</text>
          <text x="49" y="289" class="fill-gray-400 text-[12px]">Virginia</text>
        </svg>
        <figcaption class="mt-2 text-[11px] text-gray-400 leading-relaxed">
          Boundary source: US Census Bureau 2024 Cartographic Boundary Files, county layer
          (1:20,000,000). Map is a locator for the proxy region; it is not a Dominion service-territory map.
        </figcaption>
      </figure>
    </div>
  </div>
</section>
)}
