---
interface Props {
  current: "gb" | "dc-mid-atlantic";
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<nav aria-label="Region" class="border-b border-[var(--color-border)] bg-white">
  <div class="max-w-4xl mx-auto px-4">
    <ul class="flex gap-0 list-none m-0 p-0 text-sm font-medium">
      <li>
        <a
          href={`${base}/`}
          aria-current={current === "gb" ? "page" : undefined}
          class:list={[
            "inline-block px-4 py-3 border-b-2 no-underline transition-colors",
            current === "gb"
              ? "border-[var(--color-text)] text-[var(--color-text)]"
              : "border-transparent text-[var(--color-muted)] hover:text-[var(--color-text)] hover:border-gray-300",
          ]}
        >
          Great Britain
        </a>
      </li>
      <li>
        <a
          href={`${base}/dc-mid-atlantic/`}
          aria-current={current === "dc-mid-atlantic" ? "page" : undefined}
          class:list={[
            "inline-block px-4 py-3 border-b-2 no-underline transition-colors",
            current === "dc-mid-atlantic"
              ? "border-[var(--color-text)] text-[var(--color-text)]"
              : "border-transparent text-[var(--color-muted)] hover:text-[var(--color-text)] hover:border-gray-300",
          ]}
        >
          DC + Mid-Atlantic
        </a>
      </li>
    </ul>
  </div>
</nav>
