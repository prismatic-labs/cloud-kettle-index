---
import "../styles/global.css";
import RegionTabs from "./RegionTabs.astro";

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  currentRegion?: "gb" | "dc-mid-atlantic";
}

const {
  title,
  description = "Britain's data-centre electricity load, translated into kettle-boils per second. A modelled estimate by Prismatic Labs.",
  canonicalUrl,
  currentRegion,
} = Astro.props;

const base   = import.meta.env.BASE_URL.replace(/\/$/, "");
const siteUrl = (Astro.site?.toString().replace(/\/$/, "") ?? "https://prismatic-labs.github.io") + base;
const ogImage = `${siteUrl}/og.png`;
const openDataHref = currentRegion === "dc-mid-atlantic" ? `${base}/records-us` : `${base}/eir`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Cloud Kettle Index - modelled data-centre load in kettle-boils per second" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <!-- Inter font via system stack; no external font request to keep weight down -->
  </head>
  <body class="min-h-screen">
    <!-- Persistent estimate banner -->
    <div
      role="banner"
      aria-label="Methodology notice"
      class="sticky top-0 z-50 bg-amber-50 border-b border-amber-200 text-amber-900 text-sm text-center py-2 px-4 font-medium"
    >
      This is an estimate, not a live meter. -
      <a href={`${base}/methodology`} class="underline text-amber-800">
        Methodology: a modelled estimate, not a meter
      </a>
    </div>

    <header class="border-b border-[var(--color-border)] bg-white/80 backdrop-blur-sm">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href={`${base}/`} class="font-semibold text-[var(--color-text)] no-underline hover:underline">
          The Cloud Kettle Index
        </a>
        <nav aria-label="Site navigation">
          <ul class="flex gap-6 text-sm list-none m-0 p-0">
            <li><a href={`${base}/methodology`} class="text-[var(--color-muted)] hover:text-[var(--color-text)]">Methodology</a></li>
            <li><a href={`${base}/about`} class="text-[var(--color-muted)] hover:text-[var(--color-text)]">About</a></li>
            <li><a href={openDataHref} class="text-[var(--color-muted)] hover:text-[var(--color-text)]">Help make the data open</a></li>
          </ul>
        </nav>
      </div>
    </header>

    {currentRegion && <RegionTabs current={currentRegion} />}

    <main>
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-16 py-8 text-sm text-[var(--color-muted)]">
      <div class="max-w-4xl mx-auto px-4 space-y-2">
        {currentRegion === "gb" || !currentRegion ? (
          <>
            <p>
              The Great Britain page covers <strong>England, Scotland, and Wales</strong>.
              Northern Ireland operates a separate electricity system managed by SONI and is not included.
            </p>
            <p>
              Built by <a href="https://github.com/prismatic-labs">Prismatic Labs</a>.
              GB data: <a href="https://www.gov.uk/government/publications/estimate-of-data-centre-capacity-great-britain-2024">DSIT 2024</a>,
              <a href="https://developer.elexon.co.uk">Elexon BMRS</a>,
              <a href="https://api.carbonintensity.org.uk">Carbon Intensity API</a>.
              See <a href="https://github.com/prismatic-labs/vetch">vetch</a> - open-source LLM inference energy measurement.
            </p>
          </>
        ) : (
          <p>
            Built by <a href="https://github.com/prismatic-labs">Prismatic Labs</a>.
            US data: <a href="https://www.in.gov/iurc/files/1.-Data-Center-Forecasting.pdf">Dominion Energy Virginia 2025 data-centre forecasting presentation</a> (Indiana IURC filing);
            <a href="https://www.pjm.com/-/media/DotCom/committees-groups/subcommittees/las/2025/20250916/20250916-item-04ai---dominion-data-center-large-load-request.pdf">PJM Dominion data-centre large load request</a> (PJM LAS, September 2025).
            See <a href="https://github.com/prismatic-labs/vetch">vetch</a> - open-source LLM inference energy measurement.
          </p>
        )}
        <p>Apache 2.0 - <a href="https://github.com/prismatic-labs/cloud-kettle-index">source on GitHub</a></p>
      </div>
    </footer>
  </body>
</html>
